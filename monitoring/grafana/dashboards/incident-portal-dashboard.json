{
  "id": null,
  "uid": "incident-portal-dashboard",
  "title": "Incident Portal Monitoring",
  "tags": ["docker", "prometheus", "incident-portal"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Backend Up",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "up{job=\"backend\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests Per Second",
      "gridPos": { "x": 6, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(incident_http_requests_total[1m])",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Backend Response Time p95",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(incident_http_request_duration_seconds_bucket[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container Memory Usage",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name!=\"\"}",
          "refId": "A"
        }
      ]
    }
  ]
}
